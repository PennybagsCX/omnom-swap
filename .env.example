# OMNOM Swap - Environment Variables

# ─── Dogechain Deployment ───────────────────────────────────
# Private key of the deployer account (NEVER commit a real key)
PRIVATE_KEY=your_private_key_here

# Address that receives protocol fees
TREASURY_ADDRESS=0x0000000000000000000000000000000000000000

# Protocol fee in basis points (25 = 0.25%, max 500 = 5%)
PROTOCOL_FEE_BPS=25

# Dogechain RPC endpoint
DOGCHAIN_RPC_URL=https://rpc.dogechain.dog

# ─── Frontend (Vite) ────────────────────────────────────────
# RPC endpoint for the wagmi transport and constants.
# Default: public Dogechain RPC (no MEV protection).
# If a private relay becomes available, set it here to reduce
# mempool exposure and sandwich attack risk.
# VITE_RPC_URL=https://rpc.dogechain.dog

# WalletConnect Cloud project ID — required for WalletConnect support.
# Get one for free at https://cloud.walletconnect.com
# If not set, the WalletConnect option will be hidden from the wallet modal.
# VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# ─── Post-deployment Setup (optional) ───────────────────────
# Address of the deployed aggregator (for Setup.s.sol)
AGGREGATOR_ADDRESS=0x0000000000000000000000000000000000000000

# New treasury address (leave blank to skip)
# NEW_TREASURY=0x...

# New protocol fee in bps (leave blank to skip)
# NEW_FEE_BPS=10
